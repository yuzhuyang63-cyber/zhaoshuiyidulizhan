# ── 服务器配置 ──
CHAT_SERVER_HOST=127.0.0.1
CHAT_SERVER_PORT=8000
CHAT_LOG_LEVEL=INFO
CHAT_LOG_PATH=logs/chat-backend.log
CHAT_LOG_STDOUT=1
CHAT_LOG_MAX_BYTES=5242880
CHAT_LOG_BACKUP_COUNT=3
CHAT_TRANSCRIPT_LOG_PATH=logs/chat-transcript.log
CHAT_TRANSCRIPT_LOG_MAX_BYTES=5242880
CHAT_TRANSCRIPT_LOG_BACKUP_COUNT=3

# ── 邮件发送配置（QQ邮箱 SMTP）──
# 发件邮箱：你的QQ号@qq.com
# 授权码获取：mail.qq.com → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ号@qq.com
SMTP_PASSWORD=你的QQ邮箱SMTP授权码
SMTP_FROM=你的QQ号@qq.com
# 接收询盘的邮箱（可以和发件邮箱不同）
INQUIRY_TO=接收询盘的邮箱@example.com
SMTP_USE_SSL=1
SMTP_USE_TLS=0
FEISHU_ENABLED=0
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_CUSTOMER_TABLE_ID=

# Optional IP country lookup. Use {ip} as the visitor IP placeholder.
GEOIP_ENABLED=0
GEOIP_API_URL_TEMPLATE=https://ipwho.is/{ip}?lang=zh-CN
GEOIP_TIMEOUT_SECONDS=3
